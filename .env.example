# ============================================================
# Fincept AI Ops — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Application ---
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- API Security ---
# Required in production. Generate with: openssl rand -hex 32
FINCEPT_API_KEY=your-secret-api-key-here

# --- CORS ---
# Comma-separated list of allowed origins.
# NEVER use * in production.
# Example: https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Rate Limiting ---
RATE_LIMIT_PER_MIN=60
MAX_REQUEST_BYTES=1048576    # 1MB

# --- Market Data ---
# Set to 'live' to use real yfinance data, 'stub' for testing
MARKET_DATA_PROVIDER=stub

# --- Risk Limits ---
MAX_POSITION_SIZE=0.10       # Max 10% of portfolio per position
MAX_DAILY_DRAWDOWN=0.05      # Stop trading if daily loss > 5%
MAX_TRADE_SIZE_USD=1000      # Max single trade size in USD

# --- N8N Webhook ---
N8N_APPROVAL_WEBHOOK_URL=http://localhost:5678/webhook/approval
N8N_BRIEFING_WEBHOOK_URL=http://localhost:5678/webhook/briefing

# --- LLM (optional — for future agent LLM integration) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
