# === Data Providers ===
MARKET_DATA_PROVIDER=stub          # stub | yfinance

# === Paths ===
AUDIT_LOG_PATH=./data/audit/audit.jsonl
STATE_PATH=./data/state

# === Security ===
APPROVAL_SECRET=changeme           # Change in production!
CORS_ORIGINS=http://localhost:3000 # Comma-separated. "*" only for dev.
RATE_LIMIT_PER_MIN=60              # Max requests per IP per minute
MAX_REQUEST_BYTES=1048576          # 1 MB max request body

# === Risk Policy (env-configurable, no code change needed) ===
RISK_MAX_SIZE_PCT=0.10             # Max position size as fraction of portfolio
RISK_MAX_DAILY_LOSS_PCT=0.05       # Daily loss threshold before portfolio lock
