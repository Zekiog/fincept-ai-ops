# ============================================================
# Fincept AI Ops — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Application ---
APP_ENV=development          # development | production

# --- API Security ---
# REQUIRED. Generate with: openssl rand -hex 32
# Without this set, every /broker/* call returns 500.
FINCEPT_API_KEY=your-secret-api-key-here

# REQUIRED in production. Shared secret between N8N and /approval/webhook.
# Server refuses to start in production if this is empty or equals 'changeme'.
# Generate with: openssl rand -hex 32
APPROVAL_SECRET=changeme-generate-with-openssl-rand-hex-32

# --- CORS ---
# Comma-separated list of allowed origins.
# NEVER use * in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Rate Limiting ---
RATE_LIMIT_PER_MIN=60
MAX_REQUEST_BYTES=1048576    # 1MB

# --- Market Data ---
# Set to 'live' to use real yfinance data, 'stub' for testing.
MARKET_DATA_PROVIDER=stub

# --- Risk Limits (read by apps/fincept_aiops/risk_policy.py) ---
RISK_MAX_SIZE_PCT=0.10           # Max % of portfolio per position
RISK_MAX_DAILY_LOSS_PCT=0.05     # Block trading if daily loss exceeds this

# --- Persistence paths (read by state_store.py / audit_logger.py) ---
STATE_PATH=./data/state
AUDIT_LOG_PATH=./data/audit/audit.jsonl

# --- Connector Retry (read by apps/fincept_aiops/connectors/retry.py) ---
CONNECTOR_RETRY_ATTEMPTS=3
CONNECTOR_RETRY_WAIT_MAX=10

# --- LLM (optional — for future agent LLM integration) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
