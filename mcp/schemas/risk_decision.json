{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RiskDecision",
  "type": "object",
  "required": ["status"],
  "properties": {
    "status": {"type": "string", "enum": ["approved", "rejected", "review"]},
    "reason_codes": {"type": "array", "items": {"type": "string"}},
    "score": {"type": "number"},
    "checked_at": {"type": "string", "format": "date-time"}
  }
}
