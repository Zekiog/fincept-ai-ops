{
  "name": "research_gate",
  "nodes": [
    {
      "id": "trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "parameters": { "path": "research-gate", "httpMethod": "POST" }
    },
    {
      "id": "run",
      "name": "Run Research Pipeline",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "={{$env.FINCEPT_API_URL || 'http://api:8000'}}/research/run",
        "sendBody": true,
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        }
      }
    },
    {
      "id": "respond",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "parameters": { "respondWith": "json" }
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Run Research Pipeline", "type": "main", "index": 0 }]] },
    "Run Research Pipeline": { "main": [[{ "node": "Respond", "type": "main", "index": 0 }]] }
  }
}
