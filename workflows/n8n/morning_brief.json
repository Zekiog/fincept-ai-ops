{
  "name": "morning_brief",
  "nodes": [
    {
      "id": "schedule",
      "name": "Weekday 07:30",
      "type": "n8n-nodes-base.scheduleTrigger",
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "30 7 * * 1-5" }] }
      }
    },
    {
      "id": "brief",
      "name": "Build Briefing",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "={{$env.FINCEPT_API_URL || 'http://api:8000'}}/briefing/build",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"extra\":{}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        }
      }
    },
    {
      "id": "noop",
      "name": "Done",
      "type": "n8n-nodes-base.noOp",
      "parameters": {}
    }
  ],
  "connections": {
    "Weekday 07:30": { "main": [[{ "node": "Build Briefing", "type": "main", "index": 0 }]] },
    "Build Briefing": { "main": [[{ "node": "Done", "type": "main", "index": 0 }]] }
  }
}
