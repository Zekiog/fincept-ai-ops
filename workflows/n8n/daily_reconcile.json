{
  "name": "daily_reconcile",
  "nodes": [
    {
      "id": "schedule",
      "name": "Weekday 18:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "0 18 * * 1-5" }] }
      }
    },
    {
      "id": "reconcile",
      "name": "Reconcile",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "GET",
        "url": "={{$env.FINCEPT_API_URL || 'http://api:8000'}}/broker/reconcile",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{$env.FINCEPT_API_KEY}}" }
          ]
        }
      }
    },
    {
      "id": "audit",
      "name": "Audit",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "GET",
        "url": "={{$env.FINCEPT_API_URL || 'http://api:8000'}}/ui/audit"
      }
    }
  ],
  "connections": {
    "Weekday 18:00": { "main": [[{ "node": "Reconcile", "type": "main", "index": 0 }]] },
    "Reconcile": { "main": [[{ "node": "Audit", "type": "main", "index": 0 }]] }
  }
}
